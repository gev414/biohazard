{
	chapter.1000000000000001.chapter_subtitle: ["Radio protocol and courier mailbox onboarding."]
	chapter.1000000000000001.title: "NETWORK STATUS"
	chapter.2000000000000001.chapter_subtitle: ["Samples, field medicine, and biological research."]
	chapter.2000000000000001.title: "DR. MARA VOSS // MEDIC"
	chapter.3000000000000001.chapter_subtitle: ["Standing supply contracts and ammunition resupply."]
	chapter.3000000000000001.title: "ELIAS WARD // QUARTERMASTER"
	chapter.4000000000000001.chapter_subtitle: ["Encrypted requisitions, firearms, and dangerous bounties."]
	chapter.4000000000000001.title: "ROOK // ARMS BROKER"
	chapter.5000000000000001.chapter_subtitle: ["Maps, routes, and forward operating supplies."]
	chapter.5000000000000001.title: "NADIA VALE // SURVEYOR"
	chapter_group.0100000000000001.title: "SURVIVOR NETWORK // CONTACTS"
	file.0000000000000001.title: "Biohazard Survivor Network"
	quest.1100000000000001.quest_desc: [
		"A calibrated Radio Transmitter can reach the surviving logistics network."
		""
		"Accept this handshake and transmit the confirmation while remaining near the radio. Material rewards never appear instantly: couriers place them in your network mailbox after a category-based delay."
		""
		"Interact with any calibrated transmitter to collect arrived deliveries and open this pager."
	]
	quest.1100000000000001.quest_subtitle: "Establish contact with the survivor courier network."
	quest.1100000000000001.title: "OPEN FREQUENCY"
	quest.2100000000000001.quest_desc: [
		"The infection keeps changing. Voss needs confirmed infected kills and tissue that has not been sitting in a drawer for weeks."
		""
		"Kills count only after this contract is accepted. Bring the tissue back to a transmitter for collection."
	]
	quest.2100000000000001.quest_subtitle: "Voss needs fresh infected material and field observations."
	quest.2100000000000001.title: "FIELD SAMPLES"
	quest.2100000000000002.quest_desc: ["Research Data from city medical caches is more useful than another box of expired tablets. Voss will exchange two intact sets for scarce treatment supplies."]
	quest.2100000000000002.quest_subtitle: "Recovered research can reopen a better medical supply line."
	quest.2100000000000002.title: "HOSPITAL RECORDS"
	quest.3100000000000001.quest_desc: [
		"Most papers are worthless. Some still identify sealed stockrooms, convoy routes, or people who owe Ward a favor. "
		""
		"Accept over the radio, return with four Documents, then use TRANSMIT AND TURN IN. The records are consumed atomically only if the full submission is present."
	]
	quest.3100000000000001.quest_subtitle: "Ward can trade useful records for a basic ammunition shipment."
	quest.3100000000000001.title: "PAPER TRAIL"
	quest.4100000000000001.quest_desc: [
		"Rook has a lead on a secured M870, but the recovery route is buried in fragmented emergency records."
		""
		"Transmit three Documents and two sets of Research Data. Once the route is confirmed, a courier will deliver the shotgun with twenty-four 12-gauge shells."
	]
	quest.4100000000000001.quest_subtitle: "Help Rook recover an M870 and its first box of shells."
	quest.4100000000000001.title: "ENCRYPTED REQUISITION"
	quest.4100000000000002.quest_desc: [
		"Rook wants proof that the heavy infected blocking a recovery route is gone. Accept first; old kills do not count."
		""
		"The bounty pays in rifle ammunition and one field attachment."
	]
	quest.4100000000000002.quest_subtitle: "Bring down a Brute after accepting Rook's bounty."
	quest.4100000000000002.title: "HEAVY CONTACT"
	quest.4100000000000003.quest_desc: ["Rook will trade eight intact encrypted intelligence packets for a weapon drawn from his secured arsenal."]
	quest.4100000000000003.quest_subtitle: "A high-value weapon requisition for serious leverage."
	quest.4100000000000003.title: "ARSENAL CHOICE"
	quest.4100000000000004.quest_desc: ["Three encrypted intelligence packets can still buy a weapon, but the courier chooses what is available."]
	quest.4100000000000004.quest_subtitle: "A cheaper, less predictable weapon requisition."
	quest.4100000000000004.title: "FIELD ARMAMENT"
	quest.5100000000000002.quest_desc: [
		"Vale has located a sealed Waystone core, but will not release it to anyone who cannot prove they can navigate the old network."
		""
		"Bring two encrypted intel packets and a compass. The Warp Stone can be used to construct a Waystone, giving a survivor camp a permanent fast-travel anchor."
	]
	quest.5100000000000002.quest_subtitle: "Establish a permanent fast-travel anchor for a survivor camp."
	quest.5100000000000002.title: "ANCHOR POINT"
	quest.5100000000000003.quest_desc: [
		"Roads between camps are unsafe, slow, and increasingly cut off. Vale is rebuilding the old rail links one secure stretch at a time."
		""
		"Fund a field rail kit with research data, recovered records, and gold. The courier delivers rails, powered rails, detector rails, activator rails, and a minecart: enough to establish the first line between survivor camps."
	]
	quest.5100000000000003.quest_subtitle: "Secure the equipment needed to reconnect survivor camps by rail."
	quest.5100000000000003.title: "LINE STARTER"
	reward.1190000000000001.title: "COURIER: STARTER SIGNAL CACHE"
