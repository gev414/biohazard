	task.5130000000000003.title: "SUBMIT 1 DOCUMENT"
	task.5130000000000004.title: "SUBMIT 10 GOLD INGOTS"
	task.5130000000000005.title: "TRANSMIT AND TURN IN"
	quest.2E8F33AC76297DAF.quest_desc: [
		"Ward's runners can still locate 9mm, but they cannot live on ammunition alone."
		""
		"Transmit three recovered Documents and eight loaves of bread. The courier will deliver a 9mm resupply once the shipment is processed."
	]
	quest.2E8F33AC76297DAF.quest_subtitle: "Ward can spare a small 9mm shipment for records and food."
	quest.2E8F33AC76297DAF.title: "SIDEARM SUSTENANCE"
	quest.4EBC303BB34C359E.quest_desc: [
		"Shotgun shells are hard to move and costly to replace. Ward will release a box in exchange for usable records and a hot meal."
		""
		"Transmit four Documents and eight cooked porkchops to fund the delivery."
	]
	quest.4EBC303BB34C359E.quest_subtitle: "Trade records and provisions for a box of 12-gauge shells."
	quest.4EBC303BB34C359E.title: "BREACHING SHELLS"
	quest.497CAC011ACE1F27.quest_desc: [
		".45 ACP is reserved for survivors who can provide useful intelligence and help feed the quartermaster's crews."
		""
		"Transmit three sets of Research Data and six cooked steaks for a heavy-sidearm allocation."
	]
	quest.497CAC011ACE1F27.quest_subtitle: "Secure heavy sidearm ammunition with research and provisions."
	quest.497CAC011ACE1F27.title: "HEAVY SIDEARM SUPPLY"
	quest.43666292B40996F4.quest_desc: [
		"The remaining 5.7mm stores are tightly controlled. Deliver research worth preserving and enough food for the runners."
		""
		"Transmit four sets of Research Data and eight cooked chickens to request a high-velocity shipment."
	]
	quest.43666292B40996F4.quest_subtitle: "A tightly controlled high-velocity ammunition requisition."
	quest.43666292B40996F4.title: "HIGH-VELOCITY REQUISITION"
	quest.42AB0DBC8997A3D6.quest_desc: [
		"Ward has located a sealed 5.45mm shipment. Records identify the route; food keeps the retrieval team in the field."
		""
		"Transmit three Documents and eight baked potatoes for a full rifle resupply."
	]
	quest.42AB0DBC8997A3D6.quest_subtitle: "Recover an eastern-rifle allocation through Ward's supply line."
	quest.42AB0DBC8997A3D6.title: "EASTERN RIFLE RESUPPLY"
	quest.4086863D1F164E00.quest_desc: [
		"5.56mm remains the network's most requested rifle ammunition. Ward needs field reports and provisions before releasing it."
		""
		"Transmit four Documents and eight cooked steaks for a full rifle resupply."
	]
	quest.4086863D1F164E00.quest_subtitle: "Supply Ward's runners to secure a standard-rifle allocation."
	quest.4086863D1F164E00.title: "STANDARD RIFLE RESUPPLY"
	quest.4A90128EDED5EFD3.quest_desc: [
		"7.62mm is heavy, scarce, and worth the courier delay. Bring credible research and enough food to justify the run."
		""
		"Transmit four sets of Research Data and eight cooked mutton for a full-power rifle resupply."
	]
	quest.4A90128EDED5EFD3.quest_subtitle: "Trade valuable research and provisions for full-power rifle ammunition."
	quest.4A90128EDED5EFD3.title: "FULL-POWER RIFLE RESUPPLY"
